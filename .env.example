# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Access control (comma-separated, normalized to lowercase)
ALLOWED_EMAILS=jt@example.com,mary@example.com
DEFAULT_HOUSEHOLD_NAME=JT and Mary

# OpenAI (server-only)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Resend (optional, server-only)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
APP_URL=http://localhost:3000

# Feature flags
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_AI_FEATURES=true

# Local-only one-click login (never enable in production)
# Requires NODE_ENV=development, APP_URL on localhost, and a real Supabase Auth user.
ENABLE_DEV_AUTH_BYPASS=false
DEV_LOGIN_EMAIL=jt@example.com
DEV_LOGIN_PASSWORD=
